# Copy to .env.local — never commit .env.local

# Supabase (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (server-only — bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Session secret (server-only)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Default tenant (fixed UUID for single-tenant dev)
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
